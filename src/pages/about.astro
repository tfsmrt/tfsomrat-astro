---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const pages = await getCollection('pages');
const aboutPage = pages.find((p) => p.id === 'about');
const { Content } = aboutPage ? await render(aboutPage) : { Content: undefined };
---

<BaseLayout title="About – My Portfolio" description={aboutPage?.data.description}>
  <div class="about-page">
    <h1 class="page-title">{aboutPage?.data.title ?? 'About'}</h1>
    <hr class="dotted-separator" />
    <div class="page-content">
      {Content ? <Content /> : <p>About page coming soon.</p>}
    </div>
  </div>
</BaseLayout>

<style>
.about-page { padding: 1rem 0; }
.page-title { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
.page-content { margin-top: 1rem; line-height: 1.8; }
</style>
