---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts
    .filter((post) => Boolean(post.id))
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d?: Date | string) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const cleanTitle = post.data.title.replace(/\s[–—-]\s.*$/, '');
const rawBase = import.meta.env.BASE_URL; const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout title={cleanTitle} description={post.data.description}>
  <div class="post-single">
    <div class="post-single-inner">
      <div class="post-meta-col">
        <h1 class="post-title">{cleanTitle}</h1>
        <div class="post-date">↳ {formatDate(post.data.date)}</div>
        {post.data.author && <div class="post-author">by {post.data.author}</div>}
      </div>
      <div class="post-content-col">
        <div class="post-body">
          <Content />
        </div>
        {(post.data.categories ?? []).filter(Boolean).length > 0 && (
          <div class="post-taxonomy">
            Filed under:
            {(post.data.categories ?? []).map((cat, i) => (
              <span>{i > 0 ? ', ' : ''}{cat}</span>
            ))}
          </div>
        )}
        {(post.data.tags ?? []).filter(Boolean).length > 0 && (
          <div class="post-tags">
            Tags: {(post.data.tags ?? []).join(', ')}
          </div>
        )}
        <hr class="dotted-separator" />
        <a href={base} class="back-link">← All posts</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.post-single { padding: 1rem 0; }
.post-single-inner {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1.5rem;
  align-items: start;
}
.post-title { font-size: 1.6rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.5rem; }
.post-date { font-size: 0.95rem; opacity: 0.7; }
.post-author { font-size: 0.9rem; opacity: 0.6; margin-top: 0.25rem; }
.post-body { line-height: 1.8; }
.post-body :global(h1), .post-body :global(h2), .post-body :global(h3) {
  font-weight: 700; margin: 1.2rem 0 0.5rem;
}
.post-body :global(p) { margin-bottom: 1rem; }
.post-body :global(img) { max-width: 100%; border-radius: 4px; }
.post-taxonomy, .post-tags { font-size: 0.9rem; opacity: 0.7; margin-top: 0.75rem; }
.back-link { font-size: 0.95rem; opacity: 0.7; display: inline-block; margin-top: 0.75rem; }
@media (max-width: 600px) {
  .post-single-inner { grid-template-columns: 1fr; gap: 0.75rem; }
}
</style>
